DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/postgres?pgbouncer=true&connection_limit=1&sslmode=require"
DIRECT_URL="postgresql://USER:PASSWORD@HOST:PORT/postgres?pgbouncer=true&sslmode=require"

NEXTAUTH_URL="http://localhost:3000"
AUTH_SECRET="replace-with-your-auth-secret"

NEXT_PUBLIC_SUPABASE_URL="https://your-project-ref.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="replace-with-your-supabase-anon-key"

TERMII_API_KEY="replace-with-your-termii-api-key"
TERMII_SENDER_ID="replace-with-your-termii-sender-id"

# 5SIM (numbers / guest products search)
FIVE_SIM_API_KEY="replace-with-your-5sim-api-key"
# Optional override (default https://5sim.net/v1)
# FIVE_SIM_API_BASE="https://5sim.net/v1"
FIVE_SIM_GUEST_COUNTRY="usa"
FIVE_SIM_GUEST_OPERATOR="any"
# Display NGN = (5SIM Price USD * SMS_EXCHANGE_RATE) + SMS_PROFIT_MARGIN
SMS_EXCHANGE_RATE="1550"
SMS_PROFIT_MARGIN="0"

# Referrals: welcome NGN for new user who used ?ref=; referrer earns % on friend's first N number purchases.
# REFERRAL_WELCOME_NGN="100"
# REFERRAL_ORDER_PERCENT="5"
# REFERRAL_REFERRER_MAX_ORDERS="3"
# Public URL for shared links (defaults to https://abatidigital.com)
# NEXT_PUBLIC_SITE_URL="https://abatidigital.com"
